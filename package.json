{
  "name": "nda-management-system",
  "private": true,
  "scripts": {
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "node backend/index.js",
    "start:frontend": "vite --config frontend/vite.config.cjs",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon backend/index.js",
    "dev:frontend": "vite --config frontend/vite.config.cjs",
    "build": "vite build --config frontend/vite.config.cjs",
    "preview": "vite preview --config frontend/vite.config.cjs"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "axios": "^1.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "mongoose": "^8.15.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "vite": "^6.0.0"
  }
}
